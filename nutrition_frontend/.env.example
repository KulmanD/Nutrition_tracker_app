# Copy this file to ".env" and adjust as needed. Create-React-App only exposes
# variables prefixed with REACT_APP_. Restart `npm start` after changing these.

# Base URL of the backend API (the Assignment 2/3 Express server).
# Defaults to http://localhost:3000 in code if left unset.
REACT_APP_API_BASE_URL=http://localhost:3000

# Set to "true" to use local mock fixtures for the A4 AI endpoints, so the AI/socket
# UIs can be built and demoed before the real backend endpoints exist.
# Leave as "false" (or unset) to call the real backend.
REACT_APP_USE_MOCKS=false

PORT=3000

# MySQL database used by the Assignment 4 ORM layer.
DB_HOST=localhost
DB_PORT=3306
DB_NAME=nutrition_tracker
DB_USER=root
DB_PASSWORD=replace_with_local_mysql_password
DB_LOGGING=false

# Assignment 4 AI image analysis.
# Use AI_MODE=mock for deterministic local tests and demos without an API key.
# When AI_MODE is not "mock" and GEMINI_API_KEY is present, the backend calls Gemini.
AI_MODE=mock
AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_IMAGE_MODEL=gemini-3.5-flash

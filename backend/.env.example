PORT=3000

# MySQL database used by the Assignment 4 ORM layer.
DB_HOST=localhost
DB_PORT=3306
DB_NAME=nutrition_tracker
DB_USER=root
# Most local MySQL installs use an empty root password. Leave this empty unless
# your machine requires a password. Test with `mysql -u root` or `mysql -u root -p`.
DB_PASSWORD=
DB_LOGGING=false

# Assignment 4 AI image analysis.
# Use AI_MODE=mock for deterministic local tests and demos.
# With AI_MODE=real, a configured Gemini key is used; missing or failing Gemini
# calls fall back to deterministic mock data.
AI_MODE=real
AI_PROVIDER=gemini
# Optional: paste a real key only in your local backend/.env, never in this file.
# GEMINI_API_KEY=your_real_gemini_api_key_here
GEMINI_API_KEY=
GEMINI_IMAGE_MODEL=gemini-3.5-flash
